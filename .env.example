# ═══════════════════════════════════════════════════════════
#  🔱 ARGUS — Environment Configuration
#  All-Seeing Web Intelligence Platform
# ═══════════════════════════════════════════════════════════
#
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
#
#  ARGUS works without any API keys — they only enhance
#  specific checks (threat intel, screenshots).
#
# ═══════════════════════════════════════════════════════════


# ── Server ─────────────────────────────────────────────────

# Port for the backend Express API server
PORT=3001

# Application environment
# Options: development | production | test
NODE_ENV=development

# CORS origin — must match your frontend URL
# In production with Docker, set this to your public domain
CORS_ORIGIN=http://localhost:5173


# ── Timeouts & Limits ──────────────────────────────────────

# Maximum time (in ms) each individual check is allowed to run
# before being terminated. Increase if checks timeout frequently.
CHECK_TIMEOUT_MS=15000

# In-memory cache TTL (in seconds) for check results.
# Prevents redundant lookups within the window.
CACHE_TTL_SECONDS=300

# Rate limiting — max requests per window per IP
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging verbosity
# Options: error | warn | info | debug
LOG_LEVEL=info


# ── Caching (Optional) ────────────────────────────────────

# Provide a Redis URL to use distributed caching instead of
# the default in-memory LRU. Recommended for production.
#   Format: redis://[:password@]host[:port][/db]
# REDIS_URL=redis://localhost:6379


# ── API Keys (Optional) ───────────────────────────────────
#
# These keys are OPTIONAL. Without them, the corresponding
# checks will still run but with reduced functionality.
#

# VirusTotal — enhances the virustotal threat intel check
#   Sign up: https://www.virustotal.com/gui/join-us
#   Free tier: 4 requests/min, 500 requests/day
VIRUSTOTAL_API_KEY=

# Google Safe Browsing — enhances safe-browsing threat check
#   Get key: https://developers.google.com/safe-browsing/v4/get-started
#   Free tier: 10,000 requests/day
GOOGLE_SAFE_BROWSING_KEY=

# Cloudmersive — enables screenshot capture functionality
#   Sign up: https://account.cloudmersive.com/signup
#   Free tier: 800 API calls/month
CLOUDMERSIVE_API_KEY=
